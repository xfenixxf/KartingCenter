<Window x:Class="KartingCenter.Windows.TypeTOWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тип ТО" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Название типа:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="NameBox" Grid.Row="1" Margin="0,5" Height="30"/>
        <TextBlock Grid.Row="2" Text="Описание:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="DescriptionBox" Grid.Row="3" Margin="0,5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
        <TextBlock Grid.Row="4" Text="Рекомендуемый интервал (дни):" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="IntervalBox" Grid.Row="5" Margin="0,5" Height="30"/>
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveBtn" Content="Сохранить" Width="100" Height="35" Margin="5" Background="#27AE60" Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="100" Height="35" Margin="5" Background="#95A5A6" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>