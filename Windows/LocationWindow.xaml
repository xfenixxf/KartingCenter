<Window x:Class="KartingCenter.Windows.LocationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Локация" Height="228" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10,10,10,0" Height="245" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="44*"/>
            <RowDefinition Height="69*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Название локации:" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox x:Name="NameBox" Grid.Row="1" Margin="0,5,0,5" Height="30"/>

        <TextBlock Grid.Row="2" Text="Адрес:" FontWeight="Bold" Margin="0,5,0,5"/>
        <TextBox x:Name="AddressBox" Grid.Row="3" Margin="0,5,0,5" Height="30"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,64" Grid.RowSpan="2">
            <Button x:Name="SaveBtn" Content="Сохранить" Width="100" Height="35" Margin="5" Background="#27AE60" Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="100" Height="35" Margin="5" Background="#95A5A6" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>