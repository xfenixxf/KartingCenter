<Window x:Class="KartingCenter.Windows.RideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заезд" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Дата заезда:" FontWeight="Bold" Margin="0,5"/>
        <DatePicker x:Name="RideDatePicker" Grid.Row="1" Margin="0,5" Height="30"/>

        <TextBlock Grid.Row="2" Text="Время старта (ЧЧ:ММ:СС):" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="StartTimeBox" Grid.Row="3" Margin="0,5" Height="30" Text="10:00:00"/>

        <TextBlock Grid.Row="4" Text="Локация:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="LocationCombo" Grid.Row="5" Margin="0,5" Height="30" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <TextBlock Grid.Row="6" Text="Сумма оплаты (₽):" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="AmountBox" Grid.Row="7" Margin="0,5" Height="30" 
                 IsReadOnly="True" Background="#F0F0F0" Text="0.00"/>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveBtn" Content="Сохранить" Width="100" Height="35" Margin="5" 
                    Background="#27AE60" Foreground="White" Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="100" Height="35" Margin="5" 
                    Background="#95A5A6" Foreground="White" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>