<Window x:Class="KartingCenter.Windows.TOWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Техническое обслуживание" Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Карт:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="KartCombo" Grid.Row="1" Margin="0,5" Height="30" DisplayMemberPath="SerialNumber" SelectedValuePath="Id"/>
        <TextBlock Grid.Row="2" Text="Тип ТО:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="TypeTOCombo" Grid.Row="3" Margin="0,5" Height="30" DisplayMemberPath="NameType" SelectedValuePath="Id"/>
        <TextBlock Grid.Row="4" Text="Мастер:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="MasterCombo" Grid.Row="5" Margin="0,5" Height="30" DisplayMemberPath="FullName" SelectedValuePath="Id"/>
        <TextBlock Grid.Row="6" Text="Дата:" FontWeight="Bold" Margin="0,5"/>
        <DatePicker x:Name="DatePicker" Grid.Row="7" Margin="0,5" Height="30"/>
        <TextBlock Grid.Row="8" Text="Описание:" FontWeight="Bold" Margin="0,5"/>
        <TextBox x:Name="DescriptionBox" Grid.Row="9" Margin="0,5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
        <CheckBox x:Name="CompletedCheck" Grid.Row="10" Content="Завершено" Margin="0,10,0,0" VerticalAlignment="Top"/>
        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveBtn" Content="Сохранить" Width="100" Height="35" Margin="5" Background="#27AE60" Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="100" Height="35" Margin="5" Background="#95A5A6" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>