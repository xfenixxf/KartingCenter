<Window x:Class="KartingCenter.Windows.ParticipantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запись на заезд" Height="420" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Участник:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="ClientCombo" Grid.Row="1" Margin="0,5" Height="30" DisplayMemberPath="FullName" SelectedValuePath="Id"/>

        <TextBlock Grid.Row="2" Text="Команда:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="TeamCombo" Grid.Row="3" Margin="0,5" Height="30" DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <TextBlock Grid.Row="4" Text="Заезд:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="RideCombo" Grid.Row="5" Margin="0,5" Height="30" SelectedValuePath="Id"/>

        <TextBlock Grid.Row="6" Text="Карт:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="KartCombo" Grid.Row="7" Margin="0,5" Height="30" DisplayMemberPath="SerialNumber" SelectedValuePath="Id"/>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveBtn" Content="Записать" Width="100" Height="35" Margin="5" Background="#27AE60" Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="100" Height="35" Margin="5" Background="#95A5A6" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>