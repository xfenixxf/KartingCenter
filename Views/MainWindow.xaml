<Window x:Class="KartingCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Karting Center - Учёт заездов" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <TextBlock Text="Картинг-центр" FontSize="20" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="#34495E" Padding="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="StatusText" Text="Статус: Подключение..." Foreground="Yellow" Margin="10,0" FontWeight="Bold"/>
                <Border x:Name="StickerIndicator" Width="30" Height="30" CornerRadius="15" Background="Gray" Margin="10,0"/>
                <TextBlock x:Name="StatsText" Text="" Foreground="White" Margin="10,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="2" Margin="10">

            <TabItem Header="Клиенты">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#E0E0E0" Padding="5" Margin="0,0,0,10">
                        <WrapPanel>
                            <Button x:Name="AddClientBtn" Content="Добавить" Width="122" Height="30" Background="#27AE60" Foreground="White" Click="AddClientBtn_Click"/>
                            <Button x:Name="EditClientBtn" Content="Редактировать" Width="154" Height="30" Background="#F39C12" Foreground="White" Click="EditClientBtn_Click"/>
                            <Button x:Name="DeleteClientBtn" Content="Удалить" Width="100" Height="30" Margin="2" Background="#E74C3C" Foreground="White" Click="DeleteClientBtn_Click"/>
                            <Button x:Name="RefreshClientsBtn" Content="Обновить" Width="137" Height="30" Click="RefreshClientsBtn_Click"/>
                        </WrapPanel>
                    </Border>

                    <DataGrid x:Name="ClientsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="*"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="4*"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="2*"/>
                            <DataGridCheckBoxColumn Header="Постоянный" Binding="{Binding IsPermanent}" Width="1.5*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Команды">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#E0E0E0" Padding="5" Margin="0,0,0,10">
                        <WrapPanel>
                            <Button x:Name="AddTeamBtn" Content="Добавить" Width="136" Height="30" Background="#27AE60" Foreground="White" Click="AddTeamBtn_Click"/>
                            <Button x:Name="EditTeamBtn" Content="Редактировать" Width="154" Height="30" Background="#F39C12" Foreground="White" Click="EditTeamBtn_Click"/>
                            <Button x:Name="DeleteTeamBtn" Content="Удалить" Width="100" Height="30" Margin="2" Background="#E74C3C" Foreground="White" Click="DeleteTeamBtn_Click"/>
                            <Button x:Name="RefreshTeamsBtn" Content="Обновить" Width="123" Height="30" Click="RefreshTeamsBtn_Click"/>
                        </WrapPanel>
                    </Border>

                    <DataGrid x:Name="TeamsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="1*"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="5*"/>
                            <DataGridCheckBoxColumn Header="Активна" Binding="{Binding IsActive}" Width="1.5*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Типы картов">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#E0E0E0" Padding="5" Margin="0,0,0,10">
                        <WrapPanel>
                            <Button x:Name="AddCartTypeBtn" Content="Добавить" Width="125" Height="30" Background="#27AE60" Foreground="White" Click="AddCartTypeBtn_Click"/>
                            <Button x:Name="EditCartTypeBtn" Content="Редактировать" Width="154" Height="30" Background="#F39C12" Foreground="White" Click="EditCartTypeBtn_Click"/>
                            <Button x:Name="DeleteCartTypeBtn" Content="Удалить" Width="100" Height="30" Margin="2" Background="#E74C3C" Foreground="White" Click="DeleteCartTypeBtn_Click"/>
                            <Button x:Name="RefreshCartTypesBtn" Content="Обновить" Width="120" Height="30" Click="RefreshCartTypesBtn_Click"/>
                        </WrapPanel>
                    </Border>

                    <DataGrid x:Name="CartTypesGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="1*"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="3*"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding PricePerRace}" Width="1.5*"/>
                            <DataGridCheckBoxColumn Header="Доступен" Binding="{Binding IsAvailable}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Карты">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#E0E0E0" Padding="5" Margin="0,0,0,10">
                        <WrapPanel>
                            <Button x:Name="AddKartBtn" Content="Добавить" Width="126" Height="30" Background="#27AE60" Foreground="White" Click="AddKartBtn_Click"/>
                            <Button x:Name="EditKartBtn" Content="Редактировать" Width="154" Height="30" Background="#F39C12" Foreground="White" Click="EditKartBtn_Click"/>
                            <Button x:Name="DeleteKartBtn" Content="Удалить" Width="100" Height="30" Margin="2" Background="#E74C3C" Foreground="White" Click="DeleteKartBtn_Click"/>
                            <Button x:Name="RefreshKartsBtn" Content="Обновить" Width="118" Height="30" Click="RefreshKartsBtn_Click"/>
                        </WrapPanel>
                    </Border>

                    <DataGrid x:Name="KartsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="0.8*"/>
                            <DataGridTextColumn Header="Серийный номер" Binding="{Binding SerialNumber}" Width="1.5*"/>
                            <DataGridTextColumn Header="Тип карта" Binding="{Binding CartTypeName}" Width="1.5*"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="1*"/>
                            <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="0.8*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Локации">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#E0E0E0" Padding="5" Margin="0,0,0,10">
                        <WrapPanel>
                            <Button x:Name="AddLocationBtn" Content="Добавить" Width="135" Height="30" Background="#27AE60" Foreground="White" Click="AddLocationBtn_Click"/>
                            <Button x:Name="EditLocationBtn" Content="Редактировать" Width="154" Height="30" Background="#F39C12" Foreground="White" Click="EditLocationBtn_Click"/>
                            <Button x:Name="DeleteLocationBtn" Content="Удалить" Width="100" Height="30" Margin="2" Background="#E74C3C" Foreground="White" Click="DeleteLocationBtn_Click"/>
                            <Button x:Name="RefreshLocationsBtn" Content="Обновить" Width="124" Height="30" Click="RefreshLocationsBtn_Click"/>
                        </WrapPanel>
                    </Border>

                    <DataGrid x:Name="LocationsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="1*"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="3*"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="4*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Заезды">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#E0E0E0" Padding="5" Margin="0,0,0,10">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,5">
                                <Button x:Name="AddRideBtn" Content="Добавить заезд" Width="184" Height="35" Background="#27AE60" Foreground="White" Click="AddRideBtn_Click"/>
                                <Button x:Name="EditRideBtn" Content="Редактировать" Width="152" Height="35" Background="#F39C12" Foreground="White" Click="EditRideBtn_Click"/>
                                <Button x:Name="DeleteRideBtn" Content="Удалить" Width="100" Height="35" Margin="2" Background="#E74C3C" Foreground="White" Click="DeleteRideBtn_Click"/>
                                <Button x:Name="RefreshRidesBtn" Content="Обновить" Width="128" Height="35" Click="RefreshRidesBtn_Click"/>
                            </WrapPanel>
                            <WrapPanel>
                                <TextBlock Text="Фильтр по дате:" VerticalAlignment="Center" Margin="5"/>
                                <DatePicker x:Name="FilterDatePicker" Width="120" Margin="5" SelectedDateChanged="FilterDatePicker_SelectedDateChanged"/>
                                <Button x:Name="ShowAllRidesBtn" Content="Показать все" Width="126" Click="ShowAllRidesBtn_Click"/>
                                <TextBlock Text="Фильтр по месяцу:" VerticalAlignment="Center" Margin="5"/>
                                <DatePicker x:Name="MonthFilterPicker" Width="120" Margin="5" 
                SelectedDateChanged="MonthFilterPicker_SelectedDateChanged"
                DisplayDateStart="2024-01-01" DisplayDateEnd="2026-12-31"/>
                                <Button x:Name="ClearMonthFilterBtn" Content="Сбросить месяц" Width="128" 
            Click="ClearMonthFilterBtn_Click" Height="33"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="RidesGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="0.5*"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding RideDate, StringFormat=dd.MM.yyyy}" Width="1*"/>
                            <DataGridTextColumn Header="Время" Binding="{Binding StartTime}" Width="0.8*"/>
                            <DataGridTextColumn Header="Локация" Binding="{Binding LocationName}" Width="1.5*"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding AmountPaid}" Width="1*"/>
                            <DataGridTextColumn Header="Участников" Binding="{Binding ParticipantsCount}" Width="0.8*"/>
                            <DataGridTextColumn Header="Комментарий" Binding="{Binding RideData}" Width="2.5*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Участие">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#E0E0E0" Padding="5" Margin="0,0,0,10">
                        <WrapPanel>
                            <Button x:Name="AddParticipantBtn" Content="Записать участника" Width="194" Height="35" Background="#27AE60" Foreground="White" Click="AddParticipantBtn_Click"/>
                            <Button x:Name="DeleteParticipantBtn" Content="Удалить запись" Width="156" Height="35" Background="#E74C3C" Foreground="White" Click="DeleteParticipantBtn_Click"/>
                            <Button x:Name="RefreshParticipantsBtn" Content="Обновить" Width="128" Height="35" Click="RefreshParticipantsBtn_Click"/>
                        </WrapPanel>
                    </Border>

                    <DataGrid x:Name="ParticipantsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="0.5*"/>
                            <DataGridTextColumn Header="Участник" Binding="{Binding ClientName}" Width="2*"/>
                            <DataGridTextColumn Header="Команда" Binding="{Binding TeamName}" Width="1.5*"/>
                            <DataGridTextColumn Header="Заезд" Binding="{Binding RideId}" Width="0.8*"/>
                            <DataGridTextColumn Header="Карт" Binding="{Binding KartSerialNumber}" Width="1.2*"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding ParticipantDate, StringFormat=dd.MM.yyyy}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <StatusBar Grid.Row="3" Background="#2C3E50">
            <StatusBarItem>
                <TextBlock x:Name="StatusBarText" Text="Готов" Foreground="White"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>